# Gamified Platform — Environment Variables
APP_NAME=Gamified Platform
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gamified_platform
DB_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Google Gemini API (for AI quest generation)
GEMINI_API_KEY=

# File Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Leaderboard
LEADERBOARD_CACHE_TTL=300

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
